# 服务端口
PORT=8085

# ========== 数据库配置 ==========
# MySQL 主机地址
DB_HOST=localhost
# MySQL 端口
DB_PORT=3306
# 数据库名称（请根据插件需求修改）
DB_NAME=bujiaban
# 数据库用户名
DB_USER=bujiaban
# 数据库密码
DB_PASSWORD=testpassword

# ========== Redis 配置 ==========
# Redis 主机地址
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 数据库编号（不同插件建议使用不同编号，避免 key 冲突）
REDIS_DB=2

# ========== 主后端 API 配置 ==========
# 主后端 API 地址（用于调用 Plugin Auth API 验证身份和权限）
MAIN_API_URL=http://localhost:8091
# 插件名称（用于权限检查时标识插件）
PLUGIN_NAME=plugin-template-sample

# ========== Token 刷新配置 ==========
# Refresh Token 有效期（秒），默认 7 天
REFRESH_TOKEN_TTL=604800
# 每用户每分钟最大刷新次数
REFRESH_RATE_LIMIT=10
